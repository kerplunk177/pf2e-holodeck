                                </div>
                            {{else}}
                                <details class="forensics-action-card" style="border-bottom: 1px solid rgba(255, 255, 255, 0.05); cursor: pointer;" data-log-id="{{id}}" {{#if (lookup ../../expandedLogs id)}}open{{/if}}>
                                    <summary style="display: flex; list-style: none; padding: 8px 12px; align-items: center;">
                                        <div style="flex: 0 0 10%; color: #777;">{{round}}</div>
                                        <div style="flex: 0 0 25%; color: #44aaff; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">{{source}}</div>
                                        <div style="flex: 0 0 25%; color: {{#if (eq target 'None')}}#888{{else}}#ff6666{{/if}}; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">{{target}}</div>
                                        <div style="flex: 1; text-align: right; font-weight: bold; color: {{#if (eq type 'Damage')}}#ff6666{{else if (eq type 'Heal')}}#44ff44{{else}}#ffcc00{{/if}};">
                                            {{{result}}}
                                            {{#if ../../canAudit}}
                                                <a data-action="reassignLog" data-log-id="{{id}}" style="color: #44aaff; cursor: pointer; margin-left: 8px;" title="Audit / Reassign Action"><i class="fas fa-edit"></i></a>
                                                <a data-action="deleteLog" data-log-id="{{id}}" style="color: #ff4444; cursor: pointer; margin-left: 8px;" title="Delete Log"><i class="fas fa-trash"></i></a>
                                            {{/if}}
                                        </div>
                                    </summary>
                                    <div style="padding: 10px; background: rgba(0,0,0,0.5); font-family: monospace; font-size: 0.85em; border-top: 1px dashed #333;">
                                        <div style="color: #ffaa00;">Action: {{name}}</div>
                                        <div style="margin-top: 5px; color: #ccc;">{{{detail}}}</div>
                                    </div>
                                </details>
                            {{/if}}
                        {{/each}}
                    {{/each}}
                </div>
            {{/if}}

        {{else}}
            <div style="text-align: center; color: #888; padding: 40px; font-style: italic;">
                Awaiting tactical telemetry...
            </div>
        {{/if}}
    </div>
</div>